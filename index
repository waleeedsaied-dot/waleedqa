                        {avatarOpen && (
                            <div className="glass-dark neon-amber absolute bottom-14 right-0 w-80 p-8 animate-[fadeUp_0.3s_ease_both] shadow-[0_0_40px_rgba(200,96,26,0.15),0_24px_72px_rgba(0,0,0,0.8)]">
