                    </div>
                    <div className="relative" ref={popupRef}>
                        <button onClick={() => setAvatarOpen(!avatarOpen)} className={`w-10 h-10 rounded-full overflow-hidden border-2 transition-all duration-300 ${avatarOpen ? 'border-[#e8893a] shadow-[0_0_16px_rgba(200,96,26,0.5)]' : 'border-[#c8601a]/35'}`} onMouseEnter={() => setImgHover(true)} onMouseLeave={() => setImgHover(false)}>
                            <img src={PHOTO} className={`w-full h-full object-cover object-top transition-all duration-500 ${imgHover || avatarOpen ? 'grayscale-0 brightness-100' : 'grayscale brightness-[0.85]'}`} />
