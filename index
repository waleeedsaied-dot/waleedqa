                                        <p className="mono text-[0.62rem] text-[#e8893a] tracking-widest uppercase mt-1">QA Manager · BA</p>
                                        <p className="text-[0.78rem] text-[#9a8870] mt-0.5">Alexandria, Egypt</p>
                                    </div>
                                </div>
                                <div className="border-y border-white/10 py-4 mb-5">
                                    <p className="mono text-[0.6rem] tracking-[2.5px] uppercase text-[#9a8870] mb-3.5">QA Quick Stats</p>
                                    <div className="grid grid-cols-3 gap-3 text-center">
                                        {[["15+", "Years"], ["1000s", "Tests"], ["3", "Countries"]].map(([val, sub]) => (
