                                        <div key={c.label} className="flex justify-between items-center py-2 border-b border-white/5">
                                            <span className="mono text-[0.6rem] tracking-widest uppercase text-[#6a5840]">{c.label}</span>
                                            <a href={c.href} className="text-[0.8rem] text-[#c89258] hover:text-[#e8893a] transition-colors">{c.val}</a>
