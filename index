        }

        function FooterBar({ avatarOpen, setAvatarOpen, page, navigate }) {
            const popupRef = useRef(null);
            const [imgHover, setImgHover] = useState(false);
            useEffect(() => {
                const h = (e) => { if (avatarOpen && popupRef.current && !popupRef.current.contains(e.target)) setAvatarOpen(false); };
                const k = (e) => { if (e.key === "Escape") setAvatarOpen(false); };
                document.addEventListener("mousedown", h);
                document.addEventListener("keydown", k);
                return () => { document.removeEventListener("mousedown", h); document.removeEventListener("keydown", k); };
            }, [avatarOpen]);
            return (
                <div className="fixed bottom-0 left-0 right-0 z-[200] bg-[#080808]/95 backdrop-blur-2xl border-t border-white/10 px-12 py-3.5 flex items-center justify-between">
                    <div className="flex items-center gap-5">
                        <span className="bebas text-sm tracking-[3px] text-[#9a8870]">WALEED HASSAN</span>
                        <div className="hidden sm:flex gap-2.5">
                            {["ISTQB", "CAST™", "CBAP™", "15+ YRS"].map(c => (
                                <span key={c} className="mono text-[0.6rem] px-2 py-0.5 border border-[#c8601a]/20 text-[#8a7050] tracking-widest">{c}</span>
                            ))}
